{% comment %}
  ------------------------------------------------------------
  Snippet: Store Location Block
  File: snippets/store-location-block.liquid

  Renders one "Location" block for the Store Locations section.
  Each block passes its own colors and font sizes (desktop + mobile)
  as CSS variables, so every element stays individually customizable
  from the theme editor.

  Usage inside the section:
    {% render 'store-location-block', block: block %}
  ------------------------------------------------------------
{% endcomment %}

<div
  class="store-location"
  id="StoreLocation-{{ block.id }}"
  {{ block.shopify_attributes }}
  style="
    --loc-heading-color: {{ block.settings.heading_color }};
    --loc-heading-size: {{ block.settings.heading_font_size }}px;
    --loc-heading-size-mobile: {{ block.settings.heading_font_size_mobile }}px;
    --loc-address-color: {{ block.settings.address_color }};
    --loc-address-size: {{ block.settings.address_font_size }}px;
    --loc-address-size-mobile: {{ block.settings.address_font_size_mobile }}px;
    --loc-button-color: {{ block.settings.button_color }};
    --loc-button-size: {{ block.settings.button_font_size }}px;
    --loc-button-size-mobile: {{ block.settings.button_font_size_mobile }}px;
  "
>
  {% if block.settings.heading != blank %}
    <h3 class="store-location__heading">{{ block.settings.heading }}</h3>
  {% endif %}

  {% if block.settings.address != blank %}
    <div class="store-location__address">{{ block.settings.address }}</div>
  {% endif %}

  {% if block.settings.button_text != blank %}
    <a class="store-location__button" href="{{ block.settings.button_url | default: '#' }}">
      <span>{{ block.settings.button_text }}</span>
      <span class="store-location__arrow" aria-hidden="true">&#8594;</span>
    </a>
  {% endif %}
</div>
