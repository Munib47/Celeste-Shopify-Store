<style>
  .cstm-banner_with_text.cstm-img_width .fl1.imgCol {
    flex-basis: 60%;
  }

  .cstm-banner_with_text.cstm-img_width .fl1.feature-row__text {
    flex-basis: 40%;
  }

  .content-indent.default.cstm-banner_with_text.cstm-img_width {
    margin-top: 0;
  }

  .cstm-banner_with_text .feature-row .btn {
    background: transparent;
    border: none;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 5px;
    padding-left: 0;
  }

  .cstm-banner_with_text .feature-row .btn:hover {
    color: #B08053;
  }

  .cstm-banner_with_text .feature-row .btn .btn_arrow {
    transition: transform 0.25s ease;
  }

  .cstm-banner_with_text .feature-row .btn:hover .btn_arrow {
    transform: translateX(4px);
  }
  
  .cstm-banner_with_text .feature-row .btn span:first-child {
    text-decoration: underline;
  }

  .cstm-banner_with_text .subHeadingTxt {
    color: var(--shcl);
    font-size: var(--shfs);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .cstm-banner_with_text .sub-heading-divider,
  .cstm-banner_with_text .heading-divider {
    border: none;
    border-top: 1px solid;
    margin: 0 0 15px;
  }

  .cstm-banner_with_text .row-text.tc .sub-heading-divider,
  .cstm-banner_with_text .row-text.tc .heading-divider {
    margin-left: auto;
    margin-right: auto;
  }

  .cstm-banner_with_text .row-text.tr .sub-heading-divider,
  .cstm-banner_with_text .row-text.tr .heading-divider {
    margin-left: auto;
    margin-right: 0;
  }

  /* Icon with Text */
  .cstm-banner_with_text .icon-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-top: 30px;
  }

  .cstm-banner_with_text .row-text.tc .icon-text-item {
    text-align: left;
  }

  .cstm-banner_with_text .icon-text-item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }

  .cstm-banner_with_text .icon-text__icon {
    flex: 0 0 auto;
    width: 34px;
    line-height: 0;
  }

  .cstm-banner_with_text .icon-text__icon img {
    width: 100%;
    height: auto;
    display: block;
  }

  .cstm-banner_with_text .icon-text__content {
    flex: 1 1 auto;
  }

  .cstm-banner_with_text .icon-text__heading {
    color: var(--ihcl, #1a1a1a);
    font-size: var(--ihfs, 18px);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 6px;
  }

  .cstm-banner_with_text .icon-text__desc,
  .cstm-banner_with_text .icon-text__desc p {
    color: var(--ihcl, #1a1a1a);
    font-size: var(--idfs, 14px);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 767px) {
    .cstm-banner_with_text .subHeadingTxt {
      font-size: var(--shfsm);
    }

    .cstm-banner_with_text .icon-text-wrapper {
      gap: 22px;
      margin-top: 24px;
    }

    .cstm-banner_with_text .icon-text__heading {
      font-size: var(--ihfsm, 16px);
    }

    .cstm-banner_with_text .icon-text__desc,
    .cstm-banner_with_text .icon-text__desc p {
      font-size: var(--idfsm, 14px);
    }
  }

  .bwt-pad-{{ section.id }}{padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;}
  @media (max-width:767px){
    .bwt-pad-{{ section.id }}{padding-top:{{ section.settings.padding_top_mobile }}px;padding-bottom:{{ section.settings.padding_bottom_mobile }}px;}
  }
</style>

{%- assign secSt = section.settings -%}
{%- capture featureRow -%}
<div class="content-indent {{ secSt.top-offeset}}{% if secSt.section_cov %} section-cover{% endif%} cstm-banner_with_text bwt-pad-{{ section.id }}{% if section.settings.enable_custom_width == true %} cstm-img_width{% endif %}" {% if secSt.section_cov %}style="background-color:{{secSt.sec_bg_clr}};"{% endif%}>
  <div class="{% unless secSt.section_width %} page-width{% endunless %}">

    {% for block in section.blocks limit: section.blocks.size %}
      {%- assign blkSt = block.settings -%}
      {%- assign box-delay = forloop.index | minus:1 -%}
      {%- assign delay_time = 50 | times : box-delay -%}

      {%- capture image_layout -%}
      <div class="fl1 imgCol wow{% if blkSt.layout == 'right' %} fadeInRight{% else %} fadeInLeft{% endif %}" data-wow-delay="{{delay_time}}ms">
        {% if blkSt.image != blank %}
          {%- assign img_url = blkSt.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
          <span class="imgWrapper" {% if blkSt.enable_max_width == true %}style="max-width:{{ blkSt.image.width }}px;"{% endif %}>
              <img class="imgFl feature-row__image lazyload" width="{{ blkSt.image.width }}" height="{{ blkSt.image.height }}" loading="lazy"
                  data-src="{{ img_url }}" data-widths="[180, 360, 540, 720, 900]" data-aspectratio="{{ blkSt.image.aspect_ratio }}" data-sizes="auto" alt="{{ blkSt.image.alt | default : shop.name }}">
          </span>
        {% else %}
        	{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      {%- endcapture -%}

      <div class="feature-row fl f-aic f-col f-row-md{% if secSt.snow_effect %} falling-snow{% if secSt.snow_style == "style2" %} style2 {% else %} style1{% endif %}{% endif %}" style="background-color:{{blkSt.bg}};">
        {{ image_layout }}
        <div class="fl1 feature-row__text {{ blkSt.layout }} wow{% if blkSt.layout == 'right' %} fadeInLeft{% else %} fadeInRight{% endif %}" data-wow-delay="{{delay_time}}ms">
          <div class="row-text {{blkSt.text_align}}">
            {% if blkSt.sub_heading_text != blank %}
              <p class="subHeadingTxt" style="--shcl:{{blkSt.sub_heading_color}};--shfs:{{blkSt.sub_heading_font_size}}px;--shfsm:{{blkSt.sub_heading_font_size_mobile}}px;{% if blkSt.sub_heading_font_family != blank %}font-family:var(--font-{{blkSt.sub_heading_font_family}}) !important;{% endif %}">{{ blkSt.sub_heading_text }}</p>
            {% endif %}
            {% if blkSt.sub_heading_divider %}
              <hr class="sub-heading-divider" style="border-top-color:{{blkSt.sub_heading_divider_color}};width:{{blkSt.sub_heading_divider_width}}px;">
            {% endif %}
            {% if blkSt.title != blank %}
              <h3 class="ttlTxt mb{{secSt.tmbm}} mb{{secSt.tmb}}-md" style="--tcl:{{blkSt.tcl}};--tfs:{{secSt.tfs}}px;--tfsm:{{secSt.tfsm}}px;--tff:var(--{{secSt.tff}});--tfw:{{secSt.tfw}};--tlh:{{secSt.tlh}};{% if blkSt.title_font_family != blank %}font-family:var(--font-{{blkSt.title_font_family}}) !important;{% endif %}">{{ blkSt.title }}</h3>
            {% endif %}
            {% if blkSt.heading_divider %}
              <hr class="heading-divider" style="border-top-color:{{blkSt.heading_divider_color}};width:{{blkSt.heading_divider_width}}px;">
            {% endif %}
            {% if blkSt.text != blank %}
              <div class="rgTxt rte featured-row__subtext mb{{secSt.mbm}} mb{{secSt.mb}}-md" style="--cl:{{blkSt.cl}};--fs:{{secSt.fs}}px;--fsm:{{secSt.fsm}}px;--fw:{{secSt.fw}};--lh:{{secSt.lh}};{% if blkSt.text_font_family != blank %}font-family:var(--font-{{blkSt.text_font_family}}) !important;{% endif %}">
                  {{ blkSt.text }}
              </div>
            {% endif %}

            {%- if blkSt.first_icon != blank or blkSt.first_heading != blank or blkSt.first_description != blank or blkSt.second_icon != blank or blkSt.second_heading != blank or blkSt.second_description != blank or blkSt.third_icon != blank or blkSt.third_heading != blank or blkSt.third_description != blank or blkSt.fourth_icon != blank or blkSt.fourth_heading != blank or blkSt.fourth_description != blank -%}
              <div class="icon-text-wrapper" style="--ihcl:{{ blkSt.icon_text_color }};--ihfs:{{ blkSt.icon_heading_font_size }}px;--ihfsm:{{ blkSt.icon_heading_font_size_mobile_ }}px;--idfs:{{ blkSt.icon_description_font_size }}px;--idfsm:{{ blkSt.icon_description_font_size_mobile_ }}px;">

                {%- if blkSt.first_icon != blank or blkSt.first_heading != blank or blkSt.first_description != blank -%}
                  <div class="icon-text-item">
                    {% if blkSt.first_icon != blank %}
                      <div class="icon-text__icon"><img src="{{ blkSt.first_icon | img_url: '96x' }}" width="{{ blkSt.first_icon.width }}" height="{{ blkSt.first_icon.height }}" loading="lazy" alt="{{ blkSt.first_heading | default: shop.name }}"></div>
                    {% endif %}
                    <div class="icon-text__content">
                      {% if blkSt.first_heading != blank %}<h4 class="icon-text__heading"{% if blkSt.icon_heading_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_heading_font_family}}) !important"{% endif %}>{{ blkSt.first_heading }}</h4>{% endif %}
                      {% if blkSt.first_description != blank %}<div class="icon-text__desc rte"{% if blkSt.icon_description_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_description_font_family}}) !important"{% endif %}>{{ blkSt.first_description }}</div>{% endif %}
                    </div>
                  </div>
                {%- endif -%}

                {%- if blkSt.second_icon != blank or blkSt.second_heading != blank or blkSt.second_description != blank -%}
                  <div class="icon-text-item">
                    {% if blkSt.second_icon != blank %}
                      <div class="icon-text__icon"><img src="{{ blkSt.second_icon | img_url: '96x' }}" width="{{ blkSt.second_icon.width }}" height="{{ blkSt.second_icon.height }}" loading="lazy" alt="{{ blkSt.second_heading | default: shop.name }}"></div>
                    {% endif %}
                    <div class="icon-text__content">
                      {% if blkSt.second_heading != blank %}<h4 class="icon-text__heading"{% if blkSt.icon_heading_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_heading_font_family}}) !important"{% endif %}>{{ blkSt.second_heading }}</h4>{% endif %}
                      {% if blkSt.second_description != blank %}<div class="icon-text__desc rte"{% if blkSt.icon_description_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_description_font_family}}) !important"{% endif %}>{{ blkSt.second_description }}</div>{% endif %}
                    </div>
                  </div>
                {%- endif -%}

                {%- if blkSt.third_icon != blank or blkSt.third_heading != blank or blkSt.third_description != blank -%}
                  <div class="icon-text-item">
                    {% if blkSt.third_icon != blank %}
                      <div class="icon-text__icon"><img src="{{ blkSt.third_icon | img_url: '96x' }}" width="{{ blkSt.third_icon.width }}" height="{{ blkSt.third_icon.height }}" loading="lazy" alt="{{ blkSt.third_heading | default: shop.name }}"></div>
                    {% endif %}
                    <div class="icon-text__content">
                      {% if blkSt.third_heading != blank %}<h4 class="icon-text__heading"{% if blkSt.icon_heading_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_heading_font_family}}) !important"{% endif %}>{{ blkSt.third_heading }}</h4>{% endif %}
                      {% if blkSt.third_description != blank %}<div class="icon-text__desc rte"{% if blkSt.icon_description_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_description_font_family}}) !important"{% endif %}>{{ blkSt.third_description }}</div>{% endif %}
                    </div>
                  </div>
                {%- endif -%}

                {%- if blkSt.fourth_icon != blank or blkSt.fourth_heading != blank or blkSt.fourth_description != blank -%}
                  <div class="icon-text-item">
                    {% if blkSt.fourth_icon != blank %}
                      <div class="icon-text__icon"><img src="{{ blkSt.fourth_icon | img_url: '96x' }}" width="{{ blkSt.fourth_icon.width }}" height="{{ blkSt.fourth_icon.height }}" loading="lazy" alt="{{ blkSt.fourth_heading | default: shop.name }}"></div>
                    {% endif %}
                    <div class="icon-text__content">
                      {% if blkSt.fourth_heading != blank %}<h4 class="icon-text__heading"{% if blkSt.icon_heading_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_heading_font_family}}) !important"{% endif %}>{{ blkSt.fourth_heading }}</h4>{% endif %}
                      {% if blkSt.fourth_description != blank %}<div class="icon-text__desc rte"{% if blkSt.icon_description_font_family != blank %} style="font-family:var(--font-{{blkSt.icon_description_font_family}}) !important"{% endif %}>{{ blkSt.fourth_description }}</div>{% endif %}
                    </div>
                  </div>
                {%- endif -%}

              </div>
            {%- endif -%}

            {% if blkSt.button_label != blank and blkSt.button_link != blank %}
              <a href="{{ blkSt.button_link }}" class="btn {{secSt.btn-size-mob}} {{secSt.btn-size-desk}}" style="--cl:{{blkSt.btncl}};--bg:{{blkSt.btnbg}};--bd:{{blkSt.btnbd}};{% if blkSt.buttons_font_family != blank %}font-family:var(--font-{{blkSt.buttons_font_family}}) !important;{% endif %}"><span>{{ blkSt.button_label }}</span><span class="btn_arrow">→</span></a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}  
  </div>
</div>
{%- endcapture -%}
{{featureRow | strip_newlines | remove: "  " | remove: "	" }}
{% schema %}
  {
    "name": "Banner With Text",
    "class": "index-section image-with-text",
    "settings": [	  	 
	  {
            "type": "select",
            "id": "top-offeset",
            "label": "Top OffSet",
            "default": "default",
            "options": [
              {
                "value": "default",
                "label": "Default"
              },
              {
                "value": "small",
                "label": "Small"
              },
			  {
                "value": "none",
                "label": "None"
              }
			]
        },
		 {
		"type":"checkbox",
		"id":"section_width",
		"label":"Fullwidth?",
		"default": true
	  },
		 {
        "type": "checkbox",
        "id": "section_cov",
        "label": "Add Background?",
        "default": false
      },	
	  {
        "type": "color",
        "id": "sec_bg_clr",
        "label": "Background",
		"default":"#fafafa"	
	  },
	 {
		"type":"checkbox",
		"id":"snow_effect",
		"label":"Enable Snow Effect?",
		"default": false,
		"info":"For Christmas"
	   },
        {
          "type": "select",
          "id": "snow_style",
          "label": "Snow Style",
          "default": "style1",         
          "options": [
            {
            "value": "style1",
            "label": "Falling Down"
            },
            {
            "value": "style2",
            "label": "Falling From Left"
            }
            ]
          },
          {
            "type": "checkbox",
            "id": "enable_custom_width",
            "label": "Enable Custom Width of Image",
            "default": false
          },
	  {
        "type": "header",
        "content": "Appearance"
      },
      {
		"type":"paragraph",
		"content":"Title Text ====="
	  },
      {
        "type": "range",
        "id": "tfs",
        "label": "Font Size",
        "default": 30,
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px"
    },
    {
        "type": "range",
        "id": "tfsm",
        "label": "Font Size (mobile)",
        "default": 22,
        "min": 10,
        "max": 60,
        "step": 1,
        "unit": "px"
    },
    {
        "type": "select",
        "id": "tff",
        "label": "Font Family",
        "default": "ft1",
        "options": [
            {
                "value": "ft1",
                "label": "Font 1"
            },
            {
                "value": "ft2",
                "label": "Font 2"
            },
            {
                "value": "ft3",
                "label": "Font 3"
            }
        ]
    },
    {
        "type": "select",
        "id": "tfw",
        "label": "Font Weight",
        "default": "700",
        "options": [
            {
                "value": "300",
                "label": "Light"
            },
            {
                "value": "400",
                "label": "Regular"
            },
            {
                "value": "500",
                "label": "Medium"
            },
            {
                "value": "600",
                "label": "Semi Bold"
            },
            {
                "value": "700",
                "label": "Bold"
            }
        ]
    }, 	
    {
        "type": "range",
        "id": "tlh",
        "label": "Line Height",
        "default": 1.2,
        "min": 1.0,
        "max": 2.0,
        "step": 0.1,
        "info": "Space between text lines. Default is set to 1.3"
    }, 			  
    {
        "type": "range",
        "id": "tmb",
        "label": "Margin Bottom",
        "default": 15,
        "min":0,
        "max":50,
        "step":5,
        "unit": "px"
    }, 			              
    {
        "type": "range",
        "id": "tmbm",
        "label": "Margin Bottom (mobile)",
        "default": 10,
        "min":0,
        "max":50,
        "step":5,
        "unit": "px"
    },
      {
		"type":"paragraph",
		"content":"Details ====="
	  },
      {
            "type": "range",
            "id": "fs",
            "label": "Font Size",
            "default": 14,
            "min": 10,
            "max": 100,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "fsm",
            "label": "Font Size (mobile)",
            "default": 12,
            "min": 10,
            "max": 60,
            "step": 1,
            "unit": "px"
        },
        {
            "type": "select",
            "id": "fw",
            "label": "Font Weight",
            "default": "400",
            "options": [
                {
                    "value": "300",
                    "label": "Light"
                },
                {
                    "value": "400",
                    "label": "Regular"
                },
                {
                    "value": "500",
                    "label": "Medium"
                },
                {
                    "value": "600",
                    "label": "Semi Bold"
                },
                {
                    "value": "700",
                    "label": "Bold"
                }
            ]
        },
        {
            "type": "range",
            "id": "lh",
            "label": "Line Height",
            "default": 1.6,
            "min": 1.0,
            "max": 2.0,
            "step": 0.1,
            "info": "Space between text lines. Default is set to 1.3"
        }, 			  
        {
            "type": "range",
            "id": "mb",
            "label": "Margin Bottom",
            "default": 15,
            "min":0,
            "max":50,
            "step":5,
            "unit": "px"
        }, 			              
        {
            "type": "range",
            "id": "mbm",
            "label": "Margin Bottom (mobile)",
            "default": 10,
            "min":0,
            "max":50,
            "step":5,
            "unit": "px"
        },
       {
          "type": "select",
          "id": "btn-size-desk",
          "label": "Button Size: Desktop",
          "default": "btn-md",
          "options": [
              {
              "label": "Small",
              "value": "btn-sm"
              },
              {
              "label": "Medium",
              "value": "btn-md"
              },
              {
              "label": "Large",
              "value": "btn-lg"
              }	
          ]
        }, 
        {
          "type": "select",
          "id": "btn-size-mob",
          "label": "Button Size : Mobile",
          "default": "mob-btn-sm",
          "options": [
              {
              "label": "Small",
              "value": "mob-btn-sm"
              },
              {
              "label": "Medium",
              "value": "mob-btn-md"
              },
              {
              "label": "Large",
              "value": "mob-btn-lg"
              }
          ]
        },
        {
          "type": "header",
          "content": "Section Spacing"
        },
        {
          "type": "range",
          "id": "padding_top",
          "label": "Padding Top (Desktop)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "label": "Padding Bottom (Desktop)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_top_mobile",
          "label": "Padding Top (Mobile)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "padding_bottom_mobile",
          "label": "Padding Bottom (Mobile)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 30
        }
    ],
	 "blocks": [
      {
        "type": "row",
        "name": "Block",
        "settings": [
          {
            "type": "checkbox",
            "id": "enable_max_width",
            "label": "Enable Max Width",
            "default": true
          },
           {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },  
       {
            "type": "select",
            "id": "layout",
			"label":"Image alignment",
 			"default": "left",
			"options": [
        		{ "value": "left","label":"Left"},
				{ "value": "right","label":"Right"}
			]
      },
      {
        "type": "header",
        "content": "Sub Heading"
      },
      {
        "type": "text",
        "id": "sub_heading_text",
        "label": "Sub Heading Text",
        "default": "FEATURED COLLECTION"
      },
      {
        "type": "color",
        "id": "sub_heading_color",
        "label": "Sub Heading Color",
        "default": "#B08053"
      },
      {
        "type": "range",
        "label": "Sub Heading Font Size",
        "id": "sub_heading_font_size",
        "default": 24,
        "min": 2,
        "max": 50,
        "step": 2,
        "unit": "px"
      },
      {
        "type": "range",
        "label": "Sub Heading Font Size (Mobile)",
        "id": "sub_heading_font_size_mobile",
        "default": 16,
        "min": 2,
        "max": 50,
        "step": 2,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "sub_heading_font_family",
        "label": "Sub Heading Font Family",
        "default": "uni-neue",
        "options": [
          { "label": "Poppins Medium",   "value": "popins-medium" },
