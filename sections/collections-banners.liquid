{%- assign secSt = section.settings -%}
{%- capture collectionBanner -%}

{%- capture styles -%}
    --dtcl:{{secSt.cl}};
    --dtbg:{{secSt.bg | color_modify:'alpha', secSt.bxopt}};
    --dtbdr:{{secSt.bdr}}px;
    --dttfs:{{secSt.tfs}}px;
    --dttfsm:{{secSt.tfsm}}px;
    --dttff:var(--{{secSt.tff}});
    --dttfw:{{secSt.tfw}};
    --dttlh:{{secSt.tlh}};
    --dtfs:{{secSt.fs}}px;
    --dtfsm:{{secSt.fsm}}px;
    --dtfw:{{secSt.fw}};
    --dtlh:{{secSt.lh}};
    
{% endcapture %}
<style>
  .sec-{{ section.id }}{
    background-color: {{ section.settings.section_bg }};
    padding-bottom: 35px;
    }
  {%- unless secSt.show_pagination -%}
  .sec-{{ section.id }} .flickity-page-dots{
    display: none !important;
    }
  {%- endunless -%}
  .sec-{{ section.id }} .sec-ttl h2,
  .sec-{{ section.id }} .sec-ttl h3{
    font-size: {{ secSt.ttl_fsm }}px;
    }
  .sec-{{ section.id }} .sec-ttl p{
    font-size: {{ secSt.subttl_fsm }}px;
    }
  .sec-{{ section.id }} .details .btn{
    font-size: {{ secSt.btn_fsm }}px;
    }
  @media only screen and (min-width:768px){
  .sec-{{ section.id }} .sec-ttl h2,
  .sec-{{ section.id }} .sec-ttl h3{
    font-size: {{ secSt.ttl_fs }}px;
    }
  .sec-{{ section.id }} .sec-ttl p{
    font-size: {{ secSt.subttl_fs }}px;
    }
  .sec-{{ section.id }} .details .btn{
    font-size: {{ secSt.btn_fs }}px;
    }
  }

</style>
<div class="content-indent{% if secSt.hide_mobile %} hide-sm{% endif %} {{ secSt.top-offeset}} sec-{{ section.id }}" id="{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="carousel">
  <div class="clbnrs sec-{{ section.id}}{% unless secSt.section_width %} page-width{% else %} fullwidth{% if secSt.npd %} npd{% endif %}{% endunless %}{% if secSt.snow_effect %} falling-snow{% endif %}{% if secSt.snow_style == "style2" %} style2{% else %} style1{% endif %}" id="{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="masonary" style="{{styles}}">

      {% render 'sec-title', title_ff: secSt.title_font_family, subtitle_ff: secSt.subtitle_font_family %}

     
        <div class="slidebanner grid w-{{ section.settings.grid-spacing-col }}" data-flickity='{ "cellAlign":"left","groupCells":true,"wrapAround":false,"prevNextButtons": false,"pageDots":{% if secSt.show_pagination %}true{% else %}false{% endif %}{%- if secSt.autoplay -%},"autoPlay":{{secSt.speed | times: 1000}}{% endif %},"rightToLeft": false }'>
        {% for block in section.blocks limit: section.blocks.size %}      
        	{% case block.settings.width %}
              {% when '20' %}{%- assign image_size = '150,350,550,750' -%}
              {% when '25' %}{%- assign image_size = '150,350,550,750' -%}
              {% when '33' %}{%- assign image_size = '150,350,550,750' -%}
              {% when '40' %}{%- assign image_size = '150,350,550,750' -%}
              {% when '50' %}{%- assign image_size = '150,350,550,750,950' -%}
              {% when '60' %}{%- assign image_size = '550,750,950,1200,1500' -%}
              {% when '66' %}{%- assign image_size = '550,750,950,1200,1500' -%}
              {% when '75' %}{%- assign image_size = '550,750,950,1200,1500,1800' -%}
              {% when '80' %}{%- assign image_size = '550,750,950,1200,1500,1800' -%}
            {% endcase %}
        {% assign product_box = forloop.index | minus:1 %}
        {% assign delay_time = 50 | times : product_box %}
        <div class="gitem wd{{ block.settings.width }}-md wow fadeInUp" {{ block.shopify_attributes }} data-wow-delay="{{delay_time}}ms">
          {%- assign collection = collections[block.settings.collection] -%}
          {% render 'collection-grid-item', collection: collection, blkSt: block.settings, secSt: section.settings, masonary:true %}
        </div>
        {% endfor %}
        </div>
    
    {% if section.blocks.size == 0 %}{% render 'no-blocks' %}{% endif %}
  </div>
</div>
{%- endcapture -%}
{{collectionBanner | strip_newlines | remove: "  " | remove: "	" }}
