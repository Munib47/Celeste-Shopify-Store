{% comment %}
  ------------------------------------------------------------
  Section: Store Locations
  File: sections/store-locations.liquid

  - Intro column (heading, hr divider, description, button)
    comes from section settings.
  - Location blocks are rendered through the snippet:
    snippets/store-location-block.liquid
  - Desktop: intro left, blocks in a row with vertical separators.
  - Mobile: everything stacks vertically. Section settings on top,
    then blocks in order (1st, 2nd, 3rd...).
  - No JavaScript required for this section.
  ------------------------------------------------------------
{% endcomment %}

<div class="store-locations__inner" id="StoreLocations-{{ section.id }}">
  <div class="store-locations__container">

    {% comment %} ---------- Intro (section settings) ---------- {% endcomment %}
    <div class="store-locations__intro">
      {% if section.settings.heading != blank %}
        <h2 class="store-locations__heading"{% if section.settings.heading_font_family != blank %} style="font-family:var(--font-{{ section.settings.heading_font_family }}) !important"{% endif %}>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.divider %}
        <hr class="store-locations__divider">
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="store-locations__description"{% if section.settings.description_font_family != blank %} style="font-family:var(--font-{{ section.settings.description_font_family }}) !important"{% endif %}>{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a class="store-locations__button"{% if section.settings.button_font_family != blank %} style="font-family:var(--font-{{ section.settings.button_font_family }}) !important"{% endif %} href="{{ section.settings.button_url | default: '#' }}">
          <span>{{ section.settings.button_text }}</span>
          <span class="store-locations__arrow" aria-hidden="true">&#8594;</span>
        </a>
      {% endif %}
    </div>

    {% comment %} ---------- Location blocks (snippet) ---------- {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="store-locations__blocks">
        {% for block in section.blocks %}
          {% render 'store-location-block', block: block %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

{% style %}
  /* ---------- Section wrapper: background + spacing ---------- */
  #StoreLocations-{{ section.id }} {
    {% if section.settings.enable_background_color %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    {% if section.settings.enable_background_image and section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #StoreLocations-{{ section.id }} .store-locations__container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  /* ---------- Intro ---------- */
  #StoreLocations-{{ section.id }} .store-locations__intro {
    flex: 0 0 auto;
    max-width: 340px;
  }

  #StoreLocations-{{ section.id }} .store-locations__heading {
    margin: 0 0 12px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: 1.2;
    font-weight: 400;
  }

  /* Divider rendered as a real <hr> under the heading */
  #StoreLocations-{{ section.id }} .store-locations__divider {
    border: 0;
    border-top: 1px solid {{ section.settings.divider_color }};
    width: {{ section.settings.divider_width }}px;
    margin: 0 0 16px;
  }

  #StoreLocations-{{ section.id }} .store-locations__description {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_font_size }}px;
    line-height: 1.5;
    margin: 0 0 24px;
  }

  #StoreLocations-{{ section.id }} .store-locations__description p {
    margin: 0;
    color: inherit;
    font-size: inherit;
  }

  #StoreLocations-{{ section.id }} .store-locations__button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 26px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: opacity 0.25s ease;
  }

  #StoreLocations-{{ section.id }} .store-locations__button:hover {
    opacity: 0.85;
  }

  /* ---------- Blocks row ---------- */
  #StoreLocations-{{ section.id }} .store-locations__blocks {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    row-gap: 30px;
    flex: 1 1 auto;
  }

  /* ---------- Location block (markup lives in the snippet) ---------- */
  #StoreLocations-{{ section.id }} .store-location {
    padding: 0 50px;
  }

  #StoreLocations-{{ section.id }} .store-location:first-child {
    padding-left: 0;
  }

  /* Vertical separator between blocks on desktop */
  #StoreLocations-{{ section.id }} .store-location + .store-location {
    border-left: 1px solid {{ section.settings.divider_color | color_modify: 'alpha', 0.25 }};
  }

  #StoreLocations-{{ section.id }} .store-location__heading {
    margin: 0 0 14px;
    color: var(--loc-heading-color);
    font-size: var(--loc-heading-size);
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  #StoreLocations-{{ section.id }} .store-location__address {
    color: var(--loc-address-color);
    font-size: var(--loc-address-size);
    line-height: 1.6;
    margin: 0 0 18px;
  }

  #StoreLocations-{{ section.id }} .store-location__address p {
    margin: 0 0 4px;
    color: inherit;
    font-size: inherit;
  }

  #StoreLocations-{{ section.id }} .store-location__address a {
    color: inherit;
    text-decoration: none;
  }

  #StoreLocations-{{ section.id }} .store-location__button span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--loc-button-color);
    font-size: var(--loc-button-size);
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  #StoreLocations-{{ section.id }} .store-location__button span:first-child {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  #StoreLocations-{{ section.id }} .store-locations__arrow,
  #StoreLocations-{{ section.id }} .store-location__arrow {
    transition: transform 0.25s ease;
  }

  #StoreLocations-{{ section.id }} .store-locations__button:hover .store-locations__arrow,
  #StoreLocations-{{ section.id }} .store-location__button:hover .store-location__arrow {
    transform: translateX(4px);
  }

  /* ---------- Mobile: vertical stack, intro on top then blocks in order ---------- */
  @media screen and (max-width: 749px) {
    #StoreLocations-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      {% if section.settings.enable_background_image and section.settings.background_image_mobile != blank %}
        background-image: url('{{ section.settings.background_image_mobile | image_url: width: 1100 }}');
      {% endif %}
    }

    #StoreLocations-{{ section.id }} .store-locations__container {
      flex-direction: column;
      align-items: flex-start;
      gap: 36px;
      padding: 0 20px;
    }

    #StoreLocations-{{ section.id }} .store-locations__intro {
      max-width: 100%;
    }

    #StoreLocations-{{ section.id }} .store-locations__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
      padding: 0 0 30px;
      margin: 0;
    }

    #StoreLocations-{{ section.id }} .store-locations__description {
      font-size: {{ section.settings.description_font_size_mobile }}px;
    }

    #StoreLocations-{{ section.id }} .store-locations__button {
      font-size: {{ section.settings.button_font_size_mobile }}px;
    }

    #StoreLocations-{{ section.id }} .store-locations__blocks {
      flex-direction: column;
      width: 100%;
      row-gap: 0;
    }

    #StoreLocations-{{ section.id }} .store-location {
      padding: 0;
      width: 100%;
    }

    #StoreLocations-{{ section.id }} .store-location + .store-location {
      border-left: 0;
      border-top: 1px solid {{ section.settings.divider_color | color_modify: 'alpha', 0.25 }};
      margin-top: 24px;
      padding-top: 24px;
    }

    #StoreLocations-{{ section.id }} .store-location__heading {
      font-size: var(--loc-heading-size-mobile);
    }

    #StoreLocations-{{ section.id }} .store-location__address {
      font-size: var(--loc-address-size-mobile);
    }

    #StoreLocations-{{ section.id }} .store-location__button {
      font-size: var(--loc-button-size-mobile);
    }
  }
{% endstyle %}

