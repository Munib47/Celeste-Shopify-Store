{%- assign secSt = section.settings -%}
{%- if secSt.heading_size > 0 or secSt.heading_size_mobile > 0 or secSt.subheading_size > 0 or secSt.subheading_size_mobile > 0 or secSt.heading_color != blank or secSt.subheading_color != blank or secSt.date_color != blank or secSt.blog_title_color != blank or secSt.read_more_color != blank or secSt.padding_top >= 0 or secSt.padding_bottom >= 0 or secSt.padding_top_mobile >= 0 or secSt.padding_bottom_mobile >= 0 or secSt.title_padding_top >= 0 or secSt.title_padding_bottom >= 0 or secSt.heading_margin_bottom >= 0 -%}
  {%- comment -%} Fall back to the theme-wide sizes so setting one breakpoint never changes the other. {%- endcomment -%}
  {%- if secSt.heading_size > 0 -%}{%- assign hd_desk = secSt.heading_size -%}{%- else -%}{%- assign hd_desk = settings.section_heading_1_size -%}{%- endif -%}
  {%- if secSt.heading_size_mobile > 0 -%}{%- assign hd_mob = secSt.heading_size_mobile -%}{%- else -%}{%- assign hd_mob = settings.section_heading_1_size | times: 0.85 | floor -%}{%- endif -%}
  {%- if secSt.subheading_size > 0 -%}{%- assign sub_desk = secSt.subheading_size -%}{%- else -%}{%- assign sub_desk = settings.section_heading_2_size -%}{%- endif -%}
  <style>
    {%- comment -%} Desktop padding — applied at 768px+. -1 = leave theme default alone; 0+ = explicit override (including zero). {%- endcomment -%}
    @media only screen and (min-width:768px) {
      {%- if secSt.padding_top >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-top:{{ secSt.padding_top }}px; }
      {%- endif -%}
      {%- if secSt.padding_bottom >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-bottom:{{ secSt.padding_bottom }}px; }
      {%- endif -%}
      {%- if secSt.heading_size > 0 or secSt.heading_size_mobile > 0 -%}
        #shopify-section-{{ section.id }} .sec-ttl .h3.h3 { font-size:{{ hd_desk }}px; }
      {%- endif -%}
      {%- if secSt.subheading_size > 0 or secSt.subheading_size_mobile > 0 -%}
        #shopify-section-{{ section.id }} .sec-ttl p { font-size:{{ sub_desk }}px; }
      {%- endif -%}
    }
    {%- comment -%} Mobile padding + font sizes — applied below 768px. Falls back to desktop value when a mobile-specific one isn't set. {%- endcomment -%}
    @media only screen and (max-width:767px) {
      {%- if secSt.padding_top_mobile >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-top:{{ secSt.padding_top_mobile }}px; }
      {%- elsif secSt.padding_top >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-top:{{ secSt.padding_top }}px; }
      {%- endif -%}
      {%- if secSt.padding_bottom_mobile >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-bottom:{{ secSt.padding_bottom_mobile }}px; }
      {%- elsif secSt.padding_bottom >= 0 -%}
        #shopify-section-{{ section.id }} .content-indent { padding-bottom:{{ secSt.padding_bottom }}px; }
      {%- endif -%}
      {%- comment -%} FIX: these two rules previously had no media-query wrapper, so they always
      overrode the desktop font-size block above regardless of viewport (same selector/specificity,
      later in source = wins). Moving them here restores correct desktop vs mobile sizing. {%- endcomment -%}
      {%- if secSt.heading_size_mobile > 0 -%}
        #shopify-section-{{ section.id }} .sec-ttl .h3.h3 { font-size:{{ hd_mob }}px; }
      {%- endif -%}
      {%- if secSt.subheading_size_mobile > 0 -%}
        #shopify-section-{{ section.id }} .sec-ttl p { font-size:{{ secSt.subheading_size_mobile }}px; }
      {%- endif -%}
    }
    {%- if secSt.title_padding_top >= 0 -%}
      #shopify-section-{{ section.id }} .sec-ttl { padding-top:{{ secSt.title_padding_top }}px; }
    {%- endif -%}
    {%- if secSt.title_padding_bottom >= 0 -%}
      #shopify-section-{{ section.id }} .sec-ttl { padding-bottom:{{ secSt.title_padding_bottom }}px; }
    {%- endif -%}
    {%- if secSt.heading_margin_bottom >= 0 -%}
      #shopify-section-{{ section.id }} .sec-ttl .h3.h3 { margin-bottom:{{ secSt.heading_margin_bottom }}px; }
    {%- endif -%}
    {%- comment -%} .h3.h3 / doubled classes outrank this section's scoped custom_css, which also targets these elements. {%- endcomment -%}
    {%- if secSt.heading_color != blank -%}
      #shopify-section-{{ section.id }} .sec-ttl .h3.h3 { color:{{ secSt.heading_color }}; }
    {%- endif -%}
    {%- if secSt.date_color != blank -%}
      #shopify-section-{{ section.id }} .article__date.article__date { color:{{ secSt.date_color }}; }
    {%- endif -%}
    {%- if secSt.blog_title_color != blank -%}
      #shopify-section-{{ section.id }} a.article__title.article__title.article__title,
      #shopify-section-{{ section.id }} .article__title.article__title a { color:{{ secSt.blog_title_color }}; }
    {%- endif -%}
    {%- comment -%} border-color follows the text: the bdr-btn1 underline is a hardcoded border-bottom, not text-decoration. {%- endcomment -%}
    {%- if secSt.read_more_color != blank -%}
      #shopify-section-{{ section.id }} a.btn.btn { color:{{ secSt.read_more_color }}; border-color:currentColor; text-decoration-color:currentColor; }
    {%- endif -%}
    {%- if secSt.subheading_color != blank -%}
      #shopify-section-{{ section.id }} .sec-ttl p { color:{{ secSt.subheading_color }}; }
    {%- endif -%}
  </style>
{%- endif -%}
<style>
  @media only screen and (max-width:767px){
    #shopify-section-{{ section.id }} .sec-ttl{padding:0 !important;margin:0 !important;}
    #shopify-section-{{ section.id }} .sec-ttl .h3.h3{padding:0 0 30px !important;margin:0 !important;}
  }
</style>
{%- capture featuredBlog -%}
{% assign secSt = section.settings %}
<div class="content-indent {% if secSt.show_top_margin %}{{ secSt.top-offeset }}{% else %}none{% endif %}{% if secSt.section_cov %} section-cover{% endif%}" {% if secSt.section_cov %}style="background-color:{{secSt.sec_bg_clr}};"{% endif%}>
  <div class="page-width latest-blog wow fadeIn" id="blogSlider-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="carousel">

    {% render 'sec-title', title_ff: secSt.title_font_family, subtitle_ff: secSt.subtitle_font_family %}

    {% case secSt.grid %}
    	{% when 2 %}
    		{%- assign image_size = '150,350,550,750,950' -%}
    	{% when 3 %}
    		{%- assign image_size = '150,350,550,750' -%}
    	{% when 4 %}
    		{%- assign image_size = '150,350,550,750' -%}
    	{% when 5 %}
    		{%- assign image_size = '130,300,500' -%}
    	{% when 6 %}
    		{%- assign image_size = '130,300,500' -%}
    {% endcase %}

    {%- assign blog = blogs[secSt.blog] -%}

    <div class="grid rwcols-{{secSt.mobile-grid}} rwcols-md-{{secSt.tablet-grid}} rwcols-lg-{{secSt.grid}} grid--blog carousel arwOut" data-flickity='{ "cellAlign":"left","groupCells":true,"wrapAround":true,"prevNextButtons": false,"pageDots":{% if secSt.show_pagination %}true{% else %}false{% endif %}{%- if secSt.autoplay -%},"autoPlay":{{secSt.speed | times: 1000}}{% endif %}{%- if settings.rtl -%},"rightToLeft": true{%- endif -%} }'>
      {% for article in blog.articles limit: secSt.post_limit %}
      	    <div class="gitem listb-{{ forloop.index }}">{% render 'blog-card-grid', blog:blog, article:article, secSt:secSt, sizes: image_size %}</div>
       {% else %}
              {% for i in (1..secSt.post_limit) %}
                <div class="gitem">
                  <div class="wrap-blog">
                    <div class="article__grid-image mb15">{% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}{{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}</div>
                    <div class="article__grid-meta">
                      <div class="wrap-blog-inner {{ secSt.blog_align }}">
                        <h4 class="article__title"{% if secSt.article_title_font_family != blank %} style="font-family:var(--font-{{secSt.article_title_font_family}}) !important"{% endif %}><a href="#">{{ 'homepage.onboarding.blog_title' | t }}</a></h4>
                        {% if secSt.blog_show_author %}<span class="article__author"{% if secSt.meta_font_family != blank %} style="font-family:var(--font-{{secSt.meta_font_family}}) !important"{% endif %}>{{ 'homepage.onboarding.blog_author' | t }}</span>{% endif %}
                        {% if secSt.show_mini_des %}	<div class="rte article__grid-excerpt"{% if secSt.excerpt_font_family != blank %} style="font-family:var(--font-{{secSt.excerpt_font_family}}) !important"{% endif %}>{{ 'homepage.onboarding.blog_excerpt' | t }}</div> {% endif %}

                        {% if secSt.show_read_more %}
                        <ul class="list--inline article__meta-buttons">
                          <li><a href="{{ article.url }}" class="btn btn2"{% if secSt.buttons_font_family != blank %} style="font-family:var(--font-{{secSt.buttons_font_family}}) !important"{% endif %}>{{ 'blogs.article.read_more' | t }}</a></li>
                        </ul>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
    
      {% endfor %}
    </div>

    {% if secSt.show_view_all %}
    <div class="tc"><a href="{{ blog.url }}" class="btn"{% if secSt.buttons_font_family != blank %} style="font-family:var(--font-{{secSt.buttons_font_family}}) !important"{% endif %}>{{ 'blogs.article.view_all' | t }}</a></div>
    {% endif %}
  </div>
</div>
{%- endcapture -%}
{{featuredBlog | strip_newlines | remove: "  " | remove: "	" }}
