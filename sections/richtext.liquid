		{
            "type": "color",
            "id": "text_clr",
            "label": "Text Color",
			"default":"#111"	
		},
        {
            "type": "header",
            "content": "Section Spacing"
        },
        {
            "type": "range",
            "id": "padding_top",
            "label": "Padding Top",
            "min": 0,
            "max": 50,
            "step": 2,
            "unit": "px",
            "default": 36
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "label": "Padding Bottom",
            "min": 0,
            "max": 50,
            "step": 2,
            "unit": "px",
            "default": 36
        }
		
	],
	"presets": [
      {
		 "name": "Rich Text Block"         
	 }
   ]
  }
{% endschema %}

